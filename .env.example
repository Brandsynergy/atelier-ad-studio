# ── Pixa ────────────────────────────────────────────────────────────────────
# Create your API key at: https://pixa.com/dashboard/settings/api-keys
PIXA_API_KEY=your_pixa_api_key_here

# ── Anthropic (for AI copywriting) ──────────────────────────────────────────
# Create your API key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── App ──────────────────────────────────────────────────────────────────────
# The public URL of your deployed app (used for CORS / redirects)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
